# Banco de dados PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/bazar
DB_USERNAME=postgres
DB_PASSWORD=sua_senha_aqui

# JWT — use um valor longo e aleatório em produção (ex: openssl rand -hex 32)
JWT_SECRET=troque-este-valor-em-producao

# Porta do servidor (opcional, padrão 8081)
PORT=8081

# Exibir SQL no log (opcional, padrão false)
JPA_SHOW_SQL=false
